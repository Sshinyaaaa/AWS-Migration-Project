# Copy to .env for local runs (NEVER commit a real .env). Pass these via
# `docker run -e ...` in production. No secrets are baked into the image.

# Required: signing key for JWTs. The server refuses to start without it.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: SQL Server connection. If DB_HOST is unset/unreachable, the server
# runs in MOCK MODE (sanitised db.json). RDS/MSSQL is SCP-blocked in the sandbox.
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_TRUST_CERT=false

# App listens on 3000 (fixed). NODE_ENV=production serves the built dist/.
NODE_ENV=production
